@model IEnumerable<Document>
@{ ViewData["Title"] = "Quan ly tai lieu"; var docs = Model.ToList(); }

<section class="hero">
  <div class="hero-icon"><span class="svg-icon i-book"></span></div>
  <div>
    <h1>Learning Materials Made Simple</h1>
    <p>Upload tai lieu bai giang, tu dong chia chunk va chuan bi du lieu cho chatbot RAG.</p>
  </div>
</section>

<div class="stat-grid-3">
  <div class="stat-card-new"><div class="stat-round"><span class="svg-icon i-file"></span></div><div><div class="stat-label-new">Tai lieu</div><div class="stat-number">@docs.Count</div><div class="stat-desc">Tong so tai lieu</div></div></div>
  <div class="stat-card-new"><div class="stat-round"><span class="svg-icon i-cube"></span></div><div><div class="stat-label-new">Chunks</div><div class="stat-number">@docs.Sum(x => x.Chunks.Count)</div><div class="stat-desc">Doan du lieu da chia</div></div></div>
  <div class="stat-card-new"><div class="stat-round"><span class="svg-icon i-graduation"></span></div><div><div class="stat-label-new">Mon hoc</div><div class="stat-number">@docs.Select(x => x.Subject?.Name).Distinct().Count()</div><div class="stat-desc">Tong so mon hoc</div></div></div>
</div>

<div class="panel">
  @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
  <div class="panel-head">
    <h3 class="panel-title"><span class="svg-icon i-file"></span> Danh sach tai lieu</h3>
    <div class="d-flex gap-2">
      @if (User.IsInRole(UserRoles.Teacher) || User.IsInRole(UserRoles.Admin))
      {
        <a class="btn-soft" asp-controller="Research" asp-action="Index"><span class="svg-icon i-list"></span> Xem RBL</a>
        <a class="btn-main" asp-action="Upload"><span class="svg-icon i-upload"></span> Upload tai lieu</a>
      }
    </div>
  </div>
  @if (!docs.Any()) {
    <div class="empty">Chua co tai lieu nao. Hay upload file dau tien de bat dau.</div>
  } else {
    <table class="table-modern">
      <thead><tr><th>Ten file</th><th>Mon hoc</th><th>Loai</th><th>So chunk</th><th>Ngay upload</th><th>Thao tac</th></tr></thead>
      <tbody>
      @foreach (var d in docs) {
        <tr>
          <td><div class="file-cell"><div class="file-icon">@d.FileType?.ToUpper()</div><b>@d.FileName</b></div></td>
          <td>@d.Subject?.Name</td>
          <td><span class="badge-soft">@d.FileType</span></td>
          <td>@d.Chunks.Count</td>
          <td>@d.UploadedAt.ToString("dd/MM/yyyy HH:mm")</td>
          <td>
            <div class="d-flex gap-2 flex-wrap">
              <a class="btn-soft" asp-action="Details" asp-route-id="@d.Id"><span class="svg-icon i-eye"></span> Chi tiet</a>
              @if (User.IsInRole(UserRoles.Teacher) || User.IsInRole(UserRoles.Admin))
              {
                <a class="btn-warning-soft" asp-action="Edit" asp-route-id="@d.Id"><span class="svg-icon i-edit"></span> Sua</a>
              }
              @if (User.IsInRole(UserRoles.Admin))
              {
                <form asp-action="Delete" asp-route-id="@d.Id" method="post" onsubmit="return confirm('Ban chac chan muon xoa tai lieu nay?');">
                  @Html.AntiForgeryToken()
                  <button type="submit" class="btn-danger-soft"><span class="svg-icon i-trash"></span> Xoa</button>
                </form>
              }
            </div>
          </td>
        </tr>
      }
      </tbody>
    </table>
    <div class="pager"><div>Hien thi <select><option>10</option></select> tren moi trang</div><div class="pager-buttons"><div class="page-btn">&larr;</div><div class="page-btn active">1</div><div class="page-btn">&rarr;</div></div></div>
  }
</div>
