@model RAGChatbotMVC.ViewModels.RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng ký";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduRAG</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { min-height: 100vh; background: radial-gradient(circle at 30% 18%, rgba(185,255,77,.22), transparent 260px), linear-gradient(135deg, rgb(35,58,0) 0%, rgb(53,87,0) 52%, rgb(104,168,0) 100%); display: flex; align-items: center; justify-content: center; padding: 20px; }
        .card { background: rgba(255,255,255,0.96); border: 1px solid rgba(217,239,181,.85); border-radius: 14px; box-shadow: 0 20px 44px rgba(18,35,0,0.28); width: 100%; max-width: 500px; padding: 38px 34px; }
        .brand { width: 54px; height: 54px; border-radius: 14px; background: rgb(94,163,6); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 900; margin: 0 auto 18px; box-shadow: 0 10px 24px rgba(94,163,6,.25); }
        h2 { text-align: center; margin-bottom: 10px; color: rgb(32,50,10); font-weight: 800; }
        .subtitle { text-align: center; color: rgb(104,113,94); margin-bottom: 26px; font-size: 14px; line-height: 1.5; }
        .form-group { margin-bottom: 17px; }
        .form-group label { display: block; margin-bottom: 8px; color: rgb(57,67,45); font-weight: 700; }
        .form-group input, .form-group select { width: 100%; padding: 13px 14px; border: 1px solid rgb(217,239,181); border-radius: 8px; font-size: 15px; outline: none; background: rgb(251,253,245); }
        .form-group input:focus, .form-group select:focus { border-color: rgb(104,168,0); box-shadow: 0 0 0 3px rgba(104,168,0,0.18); background: #fff; }
        button { width: 100%; padding: 13px; background: linear-gradient(180deg, rgb(120,189,23), rgb(94,163,6)); color: white; border: none; border-radius: 8px; font-size: 16px; font-weight: 900; cursor: pointer; box-shadow: 0 10px 22px rgba(82,142,2,.22); }
        button:hover { filter: brightness(1.04); }
        .links { text-align: center; margin-top: 20px; }
        .links a { color: rgb(53,86,0); background: rgb(237,247,217); border: 1px solid rgb(217,239,181); border-radius: 8px; padding: 9px 12px; text-decoration: none; font-size: 14px; font-weight: 700; }
        .links a:hover { background: rgb(223,247,180); }
        .validation-summary-errors { background: #fee2e2; color: #a61818; padding: 12px 14px; border-radius: 8px; margin-bottom: 18px; font-size: 14px; }
        .validation-summary-errors ul { margin: 0; padding-left: 18px; }
        .text-danger { color: #b91c1c; font-size: 12px; display: block; margin-top: 5px; font-weight: 700; }
    </style>
</head>
<body>
    <div class="card">
        <div class="brand">ER</div>
        <h2>Tạo tài khoản mới</h2>
        <div class="subtitle">Chọn vai trò Student hoặc Teacher. Tài khoản cần Admin duyệt trước khi đăng nhập.</div>

        <form method="post" asp-action="Register">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly"></div>

            <div class="form-group">
                <label asp-for="FullName">Họ và tên</label>
                <input asp-for="FullName" placeholder="Nguyễn Văn A" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" type="email" placeholder="example@email.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RequestedRole">Vai trò đăng ký</label>
                <select asp-for="RequestedRole">
                    <option value="Student">Student </option>
                    <option value="Teacher">Teacher </option>
                </select>
                <span asp-validation-for="RequestedRole" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Password">Mật khẩu</label>
                <input asp-for="Password" type="password" placeholder="Ít nhất 6 ký tự" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ConfirmPassword">Nhập lại mật khẩu</label>
                <input asp-for="ConfirmPassword" type="password" placeholder="Nhập lại mật khẩu" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>
            <button type="submit">Đăng ký</button>
        </form>

        <div class="links">
            <a href="/Account/Login">Đã có tài khoản? Đăng nhập</a>
        </div>
    </div>
</body>
</html>
