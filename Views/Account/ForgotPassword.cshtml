@{
    Layout = null;
    ViewData["Title"] = "Quên mật khẩu";
}

<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"]</title>

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <style>

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Segoe UI',sans-serif;
            }

            body {
                height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                background: linear-gradient( 135deg, #4f46e5, #7c3aed, #9333ea);
                overflow: hidden;
            }


                body::before {
                    content: "";
                    position: absolute;
                    width: 300px;
                    height: 300px;
                    border-radius: 50%;
                    background: rgba(255,255,255,.15);
                    top: -100px;
                    left: -80px;
                }

                body::after {
                    content: "";
                    position: absolute;
                    width: 350px;
                    height: 350px;
                    border-radius: 50%;
                    background: rgba(255,255,255,.08);
                    bottom: -120px;
                    right: -120px;
                }



            .card {
                width: 430px;
                padding: 40px;
                border-radius: 30px;
                backdrop-filter: blur(20px);
                background: rgba(255,255,255,.12);
                border: 1px solid rgba(255,255,255,.2);
                box-shadow: 0 15px 40px rgba(0,0,0,.25);
                color: white;
                position: relative;
                z-index: 2;
            }


            .icon {
                width: 75px;
                height: 75px;
                border-radius: 50%;
                background: white;
                display: flex;
                justify-content: center;
                align-items: center;
                margin: auto;
                color: #6d28d9;
                font-size: 30px;
            }


            h2 {
                text-align: center;
                margin-top: 20px;
                font-size: 28px;
            }


            .subtitle {
                text-align: center;
                opacity: .8;
                margin-top: 10px;
                margin-bottom: 35px;
                line-height: 24px;
            }



            .input-box {
                position: relative;
                margin-bottom: 25px;
            }


                .input-box i {
                    position: absolute;
                    left: 18px;
                    top: 16px;
                    color: #888;
                }


                .input-box input {
                    width: 100%;
                    padding: 15px 18px 15px 50px;
                    border: none;
                    border-radius: 50px;
                    outline: none;
                    background: white;
                    font-size: 15px;
                }


            button {
                width: 100%;
                padding: 15px;
                border: none;
                border-radius: 50px;
                font-size: 16px;
                font-weight: 700;
                cursor: pointer;
                color: white;
                background: linear-gradient( 135deg, #6366f1, #9333ea);
                transition: .3s;
            }


                button:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 8px 20px rgba(0,0,0,.25);
                }


            .back {
                margin-top: 25px;
                text-align: center;
            }


                .back a {
                    color: white;
                    text-decoration: none;
                    font-size: 14px;
                }


                    .back a:hover {
                        text-decoration: underline;
                    }


            .alert {
                margin-top: 25px;
                padding: 14px;
                border-radius: 15px;
                background: rgba(34,197,94,.15);
                border: 1px solid rgba(34,197,94,.3);
                text-align: center;
                color: #dcfce7;
            }


            @media(max - width:500px) {

                .card {
                    width: 95%;
                    padding: 30px;
                }
            }

    </style>

</head>

<body>


    <div class="card">

        <div class="icon">

            <i class="fa-solid fa-lock"></i>

        </div>

        <h2>Quên mật khẩu</h2>


        <div class="subtitle">

            Nhập email đã đăng ký để nhận liên kết đặt lại mật khẩu

        </div>


        <form method="post" asp-action="ForgotPassword">


            <div class="input-box">

                <i class="fa-solid fa-envelope"></i>

                <input type="email"
                       name="email"
                       placeholder="Nhập email của bạn"
                       required>

            </div>



            <button type="submit">

                Gửi yêu cầu

            </button>

        </form>


        <div class="back">

            <a href="/Account/Login">

                <i class="fa-solid fa-arrow-left"></i>

                Quay lại đăng nhập

            </a>

        </div>



        @if (TempData["Message"] != null)
        {
            <div class="alert">

                @TempData["Message"]

            </div>
        }


    </div>


</body>

</html>