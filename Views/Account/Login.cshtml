@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduRAG</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { min-height: 100vh; background: radial-gradient(circle at 30% 18%, rgba(185,255,77,.22), transparent 260px), linear-gradient(135deg, rgb(35,58,0) 0%, rgb(53,87,0) 52%, rgb(104,168,0) 100%); display: flex; align-items: center; justify-content: center; padding: 20px; }
        .card { background: rgba(255,255,255,0.96); border: 1px solid rgba(217,239,181,.85); border-radius: 14px; box-shadow: 0 20px 44px rgba(18,35,0,0.28); width: 100%; max-width: 460px; padding: 40px 36px; }
        .brand { width: 54px; height: 54px; border-radius: 14px; background: rgb(94,163,6); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 900; margin: 0 auto 18px; box-shadow: 0 10px 24px rgba(94,163,6,.25); }
        h2 { text-align: center; margin-bottom: 10px; color: rgb(32,50,10); font-weight: 800; }
        .subtitle { text-align: center; color: rgb(104,113,94); margin-bottom: 28px; font-size: 14px; }
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; margin-bottom: 8px; color: rgb(57,67,45); font-weight: 700; }
        .form-group input { width: 100%; padding: 13px 14px; border: 1px solid rgb(217,239,181); border-radius: 8px; font-size: 15px; outline: none; background: rgb(251,253,245); }
        .form-group input:focus { border-color: rgb(104,168,0); box-shadow: 0 0 0 3px rgba(104,168,0,0.18); background: #fff; }
        button { width: 100%; padding: 13px; background: linear-gradient(180deg, rgb(120,189,23), rgb(94,163,6)); color: white; border: none; border-radius: 8px; font-size: 16px; font-weight: 900; cursor: pointer; box-shadow: 0 10px 22px rgba(82,142,2,.22); }
        button:hover { filter: brightness(1.04); }
        .links { display: flex; justify-content: center; gap: 10px; flex-wrap: wrap; margin-top: 22px; }
        .links a { color: rgb(53,86,0); background: rgb(237,247,217); border: 1px solid rgb(217,239,181); border-radius: 8px; padding: 9px 12px; text-decoration: none; font-size: 14px; font-weight: 700; }
        .links a:hover { background: rgb(223,247,180); }
        .error-message { background: #fee2e2; color: #a61818; padding: 11px 13px; border-radius: 8px; margin-bottom: 18px; text-align: center; font-size: 14px; }
        .success-message { background: rgb(237,247,217); color: rgb(35,58,0); border: 1px solid rgb(217,239,181); padding: 11px 13px; border-radius: 8px; margin-bottom: 18px; text-align: center; font-size: 14px; font-weight: 700; }
    </style>
</head>
<body>
    <div class="card">
        <div class="brand">ER</div>
        <h2>Chào mừng trở lại</h2>
        <div class="subtitle">Đăng nhập để sử dụng EduRAG</div>

        @if (TempData["Message"] != null)
        {
            <div class="success-message">@TempData["Message"]</div>
        }

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="error-message">@Html.ValidationSummary(false)</div>
        }

        <form method="post" asp-action="Login">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" placeholder="example@email.com" required autofocus />
            </div>
            <div class="form-group">
                <label>Mật khẩu</label>
                <input type="password" name="password" placeholder="••••••••" required />
            </div>
            <button type="submit">Đăng nhập</button>
        </form>

        <div class="links">
            <a href="/Account/Register">Đăng ký</a>
            <a href="/Account/ForgotPassword">Quên mật khẩu?</a>
        </div>
    </div>
</body>
</html>
