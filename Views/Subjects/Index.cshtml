@model IEnumerable<Subject>
@{ ViewData["Title"] = "Mon hoc"; var subjects = Model.ToList(); }
<div class="topbar">
  <div>
    <div class="page-kicker">Subjects</div>
    <h1 class="page-title">Quan ly mon hoc</h1>
    <p class="page-subtitle">To chuc tai lieu theo mon hoc hoac chuyen de.</p>
  </div>
  @if (User.IsInRole(UserRoles.Teacher) || User.IsInRole(UserRoles.Admin))
  {
    <a class="btn-main" asp-action="Create">Them mon hoc</a>
  }
</div>

<div class="panel">
  @if (!subjects.Any()) {
    <div class="empty">Chua co mon hoc nao.</div>
  } else {
    <table class="table-modern">
      <thead><tr><th>Ten mon hoc</th><th>Mo ta</th><th></th></tr></thead>
      <tbody>
      @foreach (var s in subjects) {
        <tr>
          <td><b>SUB @s.Name</b></td>
          <td>@s.Description</td>
          <td><span class="badge-soft">Active</span></td>
        </tr>
      }
      </tbody>
    </table>
  }
</div>
