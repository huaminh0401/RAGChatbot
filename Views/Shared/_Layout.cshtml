@{
    var fullName = User.FindFirst("FullName")?.Value;
    var displayName = !string.IsNullOrWhiteSpace(fullName)
        ? fullName
        : User.Identity?.IsAuthenticated == true ? User.Identity.Name : "Guest";
    var roleName = User.IsInRole("Admin") ? "Admin" : User.IsInRole("Teacher") ? "Teacher" : "Student";
    var canManageDocuments = User.IsInRole("Teacher") || User.IsInRole("Admin");
}
<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - EduRAG</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true">
</head>
<body>
<div class="app-shell">
    <aside class="left-panel">
        <div class="brand-row">
            <div class="brand-mark">ER</div>
            <div>
                <b>EduRAG</b>
                <small>Document AI</small>
            </div>
        </div>

        <div class="offer-title">WORKSPACE</div>
        <nav class="side-menu" aria-label="Main navigation">
            <a class="side-link" asp-controller="Documents" asp-action="Index"><span class="svg-icon i-file"></span>Tài liệu</a>
            @if (canManageDocuments)
            {
                <a class="side-link" asp-controller="Documents" asp-action="Upload"><span class="svg-icon i-upload"></span>Upload</a>
            }
            <a class="side-link" asp-controller="Research" asp-action="Index"><span class="svg-icon i-database"></span>Research</a>
            <a class="side-link" asp-controller="Chat" asp-action="Index"><span class="svg-icon i-chat"></span>Hỏi đáp</a>
        </nav>

        <div class="admin-box">
            <div class="admin-avatar"><span class="svg-icon i-user"></span></div>
            <div>
                <b>@displayName</b>
                <small>@roleName</small>
            </div>
        </div>

        <nav class="bottom-links" aria-label="Secondary navigation">
            <a asp-controller="Account" asp-action="Profile">Trang cá nhân</a>
            <a asp-controller="Subjects" asp-action="Index">Môn học</a>
            <a asp-controller="Documents" asp-action="Index">Dashboard</a>
            <a asp-controller="Research" asp-action="Index">Research</a>
            <a asp-controller="Chat" asp-action="Index">Chat</a>
            @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
            {
                <a asp-controller="Admin" asp-action="Index">Tài khoản</a>
            }
        </nav>
    </aside>

    <main class="main-stage">
        <header class="stage-top">
            <div>
                <span class="page-kicker">RAG Chatbot MVC</span>
                <h2>@ViewData["Title"]</h2>
            </div>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Account" asp-action="Logout" class="btn-danger-soft">Đăng xuất</a>
            }
        </header>
        @RenderBody()
    </main>
</div>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
