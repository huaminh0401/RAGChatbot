<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - RAG Chatbot MVC</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true">
</head>
<body>
<div class="app-shell">
    <aside class="left-panel">
        <div class="brand-row">
            <div class="brand-mark">ER</div>
            <b>EduRAG</b>
        </div>

        <div class="offer-title">CHUC NANG</div>
        <nav class="side-menu">
            <a class="side-link" asp-controller="Documents" asp-action="Index"><span class="svg-icon i-file"></span>Tai lieu</a>
            @if (User.IsInRole(UserRoles.Teacher) || User.IsInRole(UserRoles.Admin))
            {
                <a class="side-link" asp-controller="Documents" asp-action="Upload"><span class="svg-icon i-upload"></span>Upload</a>
                <a class="side-link" asp-controller="Research" asp-action="Index"><span class="svg-icon i-database"></span>Research</a>
            }
            <a class="side-link" asp-controller="Chat" asp-action="Index"><span class="svg-icon i-chat"></span>Hoi dap</a>
            @if (User.IsInRole(UserRoles.Admin))
            {
                <a class="side-link" asp-controller="Users" asp-action="Index"><span class="svg-icon i-user"></span>Users</a>
            }
        </nav>

        <div class="admin-box">
            <div class="admin-avatar"><span class="svg-icon i-user"></span></div>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div><b>@User.Identity.Name</b><small>@(User.IsInRole(UserRoles.Admin) ? "Admin" : User.IsInRole(UserRoles.Teacher) ? "Teacher" : "Student")</small></div>
                <form asp-controller="Auth" asp-action="Logout" method="post" class="ms-auto">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-button">Logout</button>
                </form>
            }
            else
            {
                <div><b>Guest</b><small>Chua dang nhap</small></div>
                <a class="logout-button ms-auto" asp-controller="Auth" asp-action="Login">Login</a>
            }
        </div>

        <div class="collapse-box">&laquo; <span>Thu gon</span></div>
        <nav class="bottom-links">
            <a asp-controller="Subjects" asp-action="Index">Mon hoc</a>
            <a asp-controller="Documents" asp-action="Index">Dashboard</a>
            @if (User.IsInRole(UserRoles.Teacher) || User.IsInRole(UserRoles.Admin))
            {
                <a asp-controller="Research" asp-action="Index">Research</a>
            }
            <a asp-controller="Chat" asp-action="Index">Chat</a>
        </nav>
    </aside>

    <main class="main-stage">
        <header class="stage-top">
            <h2>@ViewData["Title"]</h2>
        </header>
        @RenderBody()
    </main>
</div>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
