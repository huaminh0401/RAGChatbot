@model IEnumerable<ApplicationUser>
@{
    ViewData["Title"] = "Users";
    var users = Model.ToList();
}

<div class="topbar">
  <div>
    <div class="page-kicker">Admin</div>
    <h1 class="page-title">Quan ly tai khoan</h1>
    <p class="page-subtitle">Tao tai khoan, gan role va khoa/mo user.</p>
  </div>
  <a class="btn-main" asp-action="Create">Them user</a>
</div>

<div class="panel">
  @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
  <table class="table-modern">
    <thead><tr><th>Ten</th><th>Email</th><th>Username</th><th>Role</th><th>Trang thai</th><th>Thao tac</th></tr></thead>
    <tbody>
    @foreach (var user in users)
    {
      <tr>
        <td><b>@user.FullName</b></td>
        <td>@user.Email</td>
        <td>@user.UserName</td>
        <td><span class="badge-soft">@user.Role</span></td>
        <td>@(user.IsActive ? "Active" : "Locked")</td>
        <td>
          <div class="d-flex gap-2 flex-wrap">
            <a class="btn-soft" asp-action="Edit" asp-route-id="@user.Id">Sua</a>
            <form asp-action="ToggleActive" asp-route-id="@user.Id" method="post">
              @Html.AntiForgeryToken()
              <button type="submit" class="@(user.IsActive ? "btn-danger-soft" : "btn-warning-soft")">@(user.IsActive ? "Khoa" : "Mo khoa")</button>
            </form>
          </div>
        </td>
      </tr>
    }
    </tbody>
  </table>
</div>
