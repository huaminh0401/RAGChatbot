@model UserCreateViewModel
@{
    ViewData["Title"] = "Them user";
}

<div class="panel">
  <div class="panel-head">
    <h3 class="panel-title">Them tai khoan</h3>
  </div>
  <form asp-action="Create" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-6">
      <label class="form-label" asp-for="FullName">Ho ten</label>
      <input class="form-control" asp-for="FullName" />
      <span asp-validation-for="FullName" class="text-danger"></span>
    </div>
    <div class="col-md-6">
      <label class="form-label" asp-for="Email">Email</label>
      <input class="form-control" asp-for="Email" />
      <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="col-md-6">
      <label class="form-label" asp-for="UserName">Username</label>
      <input class="form-control" asp-for="UserName" />
      <span asp-validation-for="UserName" class="text-danger"></span>
    </div>
    <div class="col-md-6">
      <label class="form-label" asp-for="Role">Role</label>
      <select class="form-control" asp-for="Role">
        @foreach (var role in UserRoles.All)
        {
          <option value="@role">@role</option>
        }
      </select>
      <span asp-validation-for="Role" class="text-danger"></span>
    </div>
    <div class="col-md-6">
      <label class="form-label" asp-for="Password">Mat khau</label>
      <input class="form-control" asp-for="Password" />
      <span asp-validation-for="Password" class="text-danger"></span>
    </div>
    <div class="col-12 d-flex gap-2">
      <button class="btn-main" type="submit">Tao user</button>
      <a class="btn-soft" asp-action="Index">Huy</a>
    </div>
  </form>
</div>
