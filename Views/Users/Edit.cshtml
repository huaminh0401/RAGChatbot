@model UserEditViewModel
@{
    ViewData["Title"] = "Sua user";
}

<div class="panel">
  <div class="panel-head">
    <h3 class="panel-title">Sua tai khoan</h3>
  </div>
  <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-6">
      <label class="form-label">Email</label>
      <input class="form-control" asp-for="Email" readonly />
    </div>
    <div class="col-md-6">
      <label class="form-label">Username</label>
      <input class="form-control" asp-for="UserName" readonly />
    </div>
    <div class="col-md-6">
      <label class="form-label" asp-for="FullName">Ho ten</label>
      <input class="form-control" asp-for="FullName" />
      <span asp-validation-for="FullName" class="text-danger"></span>
    </div>
    <div class="col-md-6">
      <label class="form-label" asp-for="Role">Role</label>
      <select class="form-control" asp-for="Role">
        @foreach (var role in UserRoles.All)
        {
          <option value="@role">@role</option>
        }
      </select>
      <span asp-validation-for="Role" class="text-danger"></span>
    </div>
    <div class="col-md-6">
      <label class="form-label" asp-for="NewPassword">Mat khau moi</label>
      <input class="form-control" asp-for="NewPassword" type="password" />
      <span asp-validation-for="NewPassword" class="text-danger"></span>
    </div>
    <div class="col-md-6 d-flex align-items-center pt-4">
      <label class="form-check">
        <input class="form-check-input" asp-for="IsActive" />
        <span class="form-check-label">Active</span>
      </label>
    </div>
    <div class="col-12 d-flex gap-2">
      <button class="btn-main" type="submit">Luu</button>
      <a class="btn-soft" asp-action="Index">Huy</a>
    </div>
  </form>
</div>
